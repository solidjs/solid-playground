{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "htmlWhitespaceSensitivity": "ignore",
  "printWidth": 120,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false,
  "quoteProps": "consistent",
  "ignorePatterns": ["node_modules/", "dist/", "pnpm-lock.yaml"],
  "sortTailwindcss": {
    "config": "uno.config.js"
  }
}
